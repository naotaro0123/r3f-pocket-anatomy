# editorconfig.org
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,jsx,ts,tsx,mjs,cjs}]
# Semicolons are required by repository convention.
# EditorConfig cannot enforce them, so keep your editor/formatter aligned with oxfmt.

[*.md]
trim_trailing_whitespace = false